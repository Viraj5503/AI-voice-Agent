# =========================================================
# OPERATION: TURING ADJUSTER — environment template
# Copy to .env and fill in.  NEVER commit the real .env.
# =========================================================

# --- LLM (the conversational brain) -----------------------
# Gemini 3 Flash is the current latency-optimized model (April 2026).
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3-flash

# Anthropic — used only by the juror bot for adversarial testing.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Voice (Gradium) --------------------------------------
GRADIUM_API_KEY=
# voice_id from studio.gradium.ai — flagship "Emma" works fine to start
GRADIUM_VOICE_ID=
GRADIUM_REGION=eu       # eu or us

# --- Telephony (LiveKit / Twilio) -------------------------
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Tavily (real-time web context for Jamie) -------------
TAVILY_API_KEY=

# --- Pioneer / Fastino (extraction fine-tune + eval) -----
FASTINO_API_KEY=
FASTINO_PIONEER_PROJECT=

# --- Bridge / dashboard ----------------------------------
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8765

# Which CRM mock to inject for the demo call
DEMO_CRM_PROFILE=max_mueller
